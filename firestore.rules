rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper function: Check if user is authenticated ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Helper function: Check if user document belongs to logged-in user ---
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. User Profile Rules
    match /users/{userId} {
      allow read: if true; // Public directories so people can see reputations/pics
      allow write: if isOwner(userId); // Only self profile can be created or updated
    }

    // 2. Wishes (Mutual Aid Requests) Rules
    match /wishes/{wishId} {
      allow read: if true; // Everyone can find aid feeds
      allow create: if isAuthenticated(); // Must have account to request aid
      allow update: if isAuthenticated() && (
        request.resource.data.creatorId == request.auth.uid || 
        resource.data.fulfillerId == request.auth.uid
      ); // Only creator or assigned helper can update wish status
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // 3. Offers (Replies to help) Rules
    match /offers/{offerId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated(); 
      allow update, delete: if isAuthenticated() && (
        resource.data.providerId == request.auth.uid ||
        get(/databases/$(database)/documents/wishes/$(resource.data.wishId)).data.creatorId == request.auth.uid
      ); // Only the helper provider can edit/delete, or the wish creator can accept/update
    }

    // 4. Chat Messages Rules
    match /chat_messages/{messageId} {
      allow read, create: if isAuthenticated() && (
        request.resource.data.senderId == request.auth.uid ||
        request.resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      ); // Only sender or receiver of a direct chat can read or write messages
    }
  }
}
